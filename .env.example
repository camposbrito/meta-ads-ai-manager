# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=meta_ads_db
DB_NAME_TEST=meta_ads_db_test

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Encryption
ENCRYPTION_KEY=your-encryption-key-change-in-production

# JWT Configuration
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
PASSWORD_RESET_SECRET=your-password-reset-secret-change-in-production
PASSWORD_RESET_EXPIRES_IN=1h

# Meta Ads API Configuration
META_ADS_APP_ID=your_app_id_here
META_ADS_APP_SECRET=your_app_secret_here
META_ADS_REDIRECT_URI=http://localhost:3000/auth/meta/callback
VITE_META_APP_ID=your_app_id_here
VITE_META_REDIRECT_URI=http://localhost:5173/meta/callback
VITE_META_SCOPES=ads_management,ads_read,business_management

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Stripe Configuration (for billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_price_id_here
STRIPE_PRICE_PRO_YEARLY=price_your_pro_yearly_price_id_here
STRIPE_PRICE_AGENCY_MONTHLY=price_your_agency_monthly_price_id_here
STRIPE_PRICE_AGENCY_YEARLY=price_your_agency_yearly_price_id_here

# Frontend URL for Stripe checkout redirects
FRONTEND_URL=http://localhost:5173

# SMTP (password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Meta Ads AI Manager <no-reply@metaadsai.local>"

# Optimization safeguards
OPTIMIZATION_AUTO_ACTION_DAILY_LIMIT=25
OPTIMIZATION_MIN_IMPRESSIONS=500
OPTIMIZATION_MIN_SPEND=20
OPTIMIZATION_MIN_CONFIDENCE=0.65
OPTIMIZATION_SUGGESTION_COOLDOWN_HOURS=24
OPTIMIZATION_AUTO_EXECUTE_MIN_CONFIDENCE=0.85
OPTIMIZATION_AUTO_ACTIONS_PER_RUN=5

# Support channels by plan
SUPPORT_COMMUNITY_URL=https://github.com/camposbrito/meta-ads-ai-manager/discussions
SUPPORT_EMAIL=suporte@seu-dominio.com
SUPPORT_PRIORITY_EMAIL=priority@seu-dominio.com
SUPPORT_DEDICATED_CHANNEL_URL=https://wa.me/5500000000000
